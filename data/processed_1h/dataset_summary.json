{
  "network": {
    "source": "MATPOWER case33bw radial distribution test feeder",
    "num_buses": 33,
    "num_branches": 37,
    "total_base_load_MW": 3.715
  },
  "load": {
    "source": "Ausgrid Distribution Zone Substation Data",
    "num_selected_zones": 33,
    "mapping_file": "data/processed_1h/zone_to_bus_mapping.csv",
    "note": "zone substation demand may represent net demand at substation level"
  },
  "solar": {
    "source": "AEMO NEMWeb Dispatch SCADA",
    "metadata_source": "AEMO CDEII available-generator metadata",
    "region": "NSW1",
    "num_solar_duids": 49,
    "num_mapped_solar_duids": 36,
    "pv_buses": [6, 13, 18, 25, 30],
    "target_total_pv_capacity_MW": 1.6,
    "mapping_file": "data/processed_1h/solar_to_bus_mapping.csv",
    "coordinate_note": "CDEII metadata identify solar DUIDs but do not provide plant-level latitude/longitude used by this experiment."
  },
  "price": {
    "source": "AEMO DispatchIS",
    "region": "NSW1",
    "selected_price_field": "RRP"
  },
  "alignment": {
    "timezone": "UTC",
    "timestamp_convention": "interval_start_utc",
    "resolution": "1H",
    "start_time_utc": "2023-01-01T00:00:00Z",
    "end_time_utc": "2023-12-31T23:00:00Z",
    "num_records": 8760
  },
  "included_files": [
    "data/processed_1h/aligned_dataset.csv",
    "data/processed_1h/price_timeseries.csv",
    "data/processed_1h/feeder_bus.csv",
    "data/processed_1h/feeder_branch.csv",
    "data/processed_1h/zone_to_bus_mapping.csv",
    "data/processed_1h/solar_to_bus_mapping.csv",
    "data/processed_1h/aemo_nsw_solar_farm_metadata.csv",
    "data/processed_1h/dataset_summary.json"
  ],
  "excluded_files": [
    {
      "name": "raw_or_5min_scada_files",
      "reason": "large intermediate source files; the hourly aligned dataset used by the experiments is included"
    },
    {
      "name": "cached_forecast_predictions",
      "reason": "forecasts are generated by scripts/train_forecaster.py"
    }
  ],
  "resampling": {
    "method": "mean for power and price; price_pu recomputed after resampling"
  }
}
