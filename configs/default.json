{
  "dataset": {
    "aligned_dataset": "data/processed_1h/aligned_dataset.csv",
    "price_timeseries": "data/processed_1h/price_timeseries.csv",
    "branch_table": "data/processed_1h/feeder_branch.csv",
    "bus_table": "data/processed_1h/feeder_bus.csv"
  },
  "forecast": {
    "input_hours": 48,
    "horizon_hours": 24,
    "predictor": "stgnn",
    "train_period": ["2023-01-01T00:00:00Z", "2023-10-31T23:00:00Z"],
    "test_period": ["2023-11-01T00:00:00Z", "2023-12-31T23:00:00Z"]
  },
  "dispatch": {
    "solver": "gurobi",
    "time_limit_seconds": 120,
    "voltage_bounds_pu": [0.95, 1.05],
    "dg_cost_type": "quadratic",
    "rt_buy_price_adder_AUD_per_MWh": 50.0,
    "rt_sell_price_ratio": 0.5
  },
  "closed_loop": {
    "K_max": 5,
    "train_month": "2023-11",
    "test_month": "2023-12",
    "marginal_map_mode": "dual",
    "marginal_direction_mode": "bidirectional",
    "use_boundary_channel": true,
    "corrector_architecture": "graphflow",
    "base_rho": 4.5,
    "perturb_eps": 0.15,
    "boundary_kappa": 1.0,
    "bmc_loss_weight": 0.5,
    "lambda_br": 0.01,
    "regret_alpha": 1.5,
    "regret_weight_cap": 5.0,
    "settlement_system_weight": 0.0,
    "settlement_node_weight": 0.0
  }
}

